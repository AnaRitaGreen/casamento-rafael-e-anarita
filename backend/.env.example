# ── Banco de Dados ──────────────────────────────────────────── #
# Opção 1: URL completa
# DATABASE_URL=postgres://noivos_admin:SuaSenhaSuperSeguraAqui@localhost:5432/casamento_db

# Opção 2: variáveis individuais
DB_HOST=localhost
DB_PORT=5432
DB_USER=noivos_admin
DB_PASSWORD=SuaSenhaSuperSeguraAqui
DB_NAME=casamento_db

# ── Autenticação ─────────────────────────────────────────────── #
# OBRIGATÓRIO: chave secreta para assinar os JWTs
# Gere uma chave forte: openssl rand -hex 32
JWT_SECRET=TROQUE-POR-UMA-CHAVE-FORTE-DE-32-CHARS-OU-MAIS

# ── Servidor ─────────────────────────────────────────────────── #
PORT=8080

# ── CORS ─────────────────────────────────────────────────────── #
ALLOWED_ORIGIN=http://localhost:4321
# ALLOWED_ORIGIN=https://casamento-rafael-e-anarita.vercel.app

# ── Postgres Docker (espelha DB_*) ───────────────────────────── #
# Usado pelo container Docker do PostgreSQL (env_file no compose)
POSTGRES_USER=noivos_admin
POSTGRES_PASSWORD=SuaSenhaSuperSeguraAqui
POSTGRES_DB=casamento_db
