---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Dashboard — Painel dos Noivos"
  description="Painel de gerenciamento de convidados do casamento de Rafael e Anarita."
>
  <!-- Sidebar + Main layout -->
  <div
    id="dashboard-app"
    style="display:flex; min-height:100vh; background:var(--creme);"
  >
    <!-- ── Sidebar ──────────────────────────────────────── -->
    <aside
      id="sidebar"
      style="
      width: 260px;
      background: linear-gradient(180deg, var(--lavanda-dark) 0%, #6b50bb 100%);
      color: white;
      padding: 2rem 1.5rem;
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
    "
    >
      <!-- Logo -->
      <div style="text-align:center; margin-bottom:2.5rem;">
        <p
          class="font-cursive"
          style="font-size:2rem; color:rgba(255,255,255,0.95);"
        >
          R & A
        </p>
        <p
          style="font-size:0.75rem; opacity:0.65; letter-spacing:0.1em; text-transform:uppercase;"
        >
          Painel dos Noivos
        </p>
      </div>

      <!-- Nav -->
      <nav style="flex:1;">
        <a
          href="#overview"
          class="sidebar-link active-link"
          id="nav-overview"
          onclick="showTab('overview', this)"
        >
          📊 Visão Geral
        </a>
        <a
          href="#guests"
          class="sidebar-link"
          id="nav-guests"
          onclick="showTab('guests', this)"
        >
          👥 Convidados
        </a>
        <a
          href="#messages"
          class="sidebar-link"
          id="nav-messages"
          onclick="showTab('messages', this)"
        >
          💌 Mensagens
        </a>
        <a
          href="#export"
          class="sidebar-link"
          id="nav-export"
          onclick="showTab('export', this)"
        >
          📥 Exportar
        </a>
        <a
          href="#presentes"
          class="sidebar-link"
          id="nav-presentes"
          onclick="showTab('presentes', this)"
        >
          🎁 Presentes
        </a>
      </nav>

      <!-- Footer sidebar -->
      <div
        style="border-top:1px solid rgba(255,255,255,0.2); padding-top:1.25rem; margin-top:auto;"
      >
        <a
          href="/"
          style="color:rgba(255,255,255,0.7); font-size:0.85rem; text-decoration:none;"
          >← Ver Site</a
        >
        <br />
        <button
          onclick="handleLogout()"
          style="background:none;border:none;color:rgba(255,255,255,0.6);cursor:pointer;font-size:0.85rem;margin-top:0.5rem;font-family:'Quicksand';"
        >
          🚪 Sair
        </button>
      </div>
    </aside>

    <!-- ── Main Content ─────────────────────────────────── -->
    <main style="flex:1; padding:2.5rem; overflow-x:hidden;">
      <!-- TAB: Visão Geral -->
      <div id="tab-overview" class="tab-content">
        <h1
          style=" font-size:2.5rem; color:var(--lavanda-dark); margin-bottom:0.25rem;"
        >
          Visão Geral
        </h1>
        <p style="color:var(--texto-suave); margin-bottom:2rem;">
          Atualizado em tempo real
        </p>

        <!-- Métricas -->
        <div
          id="metrics-grid"
          style="display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:1.25rem; margin-bottom:2.5rem;"
        >
          <div
            class="metric-card"
            style="background:linear-gradient(135deg,var(--lavanda),var(--azul)); color:white;"
          >
            <div class="metric-number" id="m-total">—</div>
            <div class="metric-label">Total de Convidados</div>
          </div>
          <div
            class="metric-card"
            style="background:linear-gradient(135deg,var(--menta-dark),#52c77a); color:white;"
          >
            <div class="metric-number" id="m-confirmados">—</div>
            <div class="metric-label">Confirmados ✅</div>
          </div>
          <div
            class="metric-card"
            style="background:linear-gradient(135deg,#e07b7b,#d45f5f); color:white;"
          >
            <div class="metric-number" id="m-recusados">—</div>
            <div class="metric-label">Não vão ❌</div>
          </div>
          <div
            class="metric-card"
            style="background:linear-gradient(135deg,#e0c07b,#c9a840); color:white;"
          >
            <div class="metric-number" id="m-pendentes">—</div>
            <div class="metric-label">Pendentes ⏳</div>
          </div>
        </div>

        <!-- Barra de progresso -->
        <div class="glass-card" style="padding:1.75rem; margin-bottom:2rem;">
          <div
            style="display:flex; justify-content:space-between; margin-bottom:0.75rem;"
          >
            <span style="font-weight:600; color:var(--texto);"
              >Progresso de Confirmações</span
            >
            <span
              id="progress-pct"
              style="color:var(--lavanda-dark); font-weight:700;">0%</span
            >
          </div>
          <div
            style="background:#ede8f5; border-radius:50px; height:12px; overflow:hidden;"
          >
            <div
              id="progress-bar"
              style="height:100%; width:0%; background:linear-gradient(90deg,var(--lavanda),var(--menta)); border-radius:50px; transition:width 1s ease;"
            >
            </div>
          </div>
          <div
            style="display:flex; justify-content:space-between; margin-top:0.5rem; font-size:0.8rem; color:var(--texto-suave);"
          >
            <span id="prog-confirmed">0 confirmados</span>
            <span id="prog-total">de 0 convidados</span>
          </div>
        </div>

        <div
          id="overview-loading"
          style="text-align:center; color:var(--texto-suave); padding:2rem;"
        >
          Carregando dados... <span
            style="animation: float 1s ease-in-out infinite; display:inline-block;"
            >💜</span
          >
        </div>
      </div>

      <!-- TAB: Convidados -->
      <div id="tab-guests" class="tab-content" style="display:none;">
        <div
          style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:1rem; margin-bottom:2rem;"
        >
          <div>
            <h1
              style=" font-size:2.5rem; color:var(--lavanda-dark); margin-bottom:0.25rem;"
            >
              Convidados
            </h1>
            <p style="color:var(--texto-suave);">
              Gerencie sua lista de convidados
            </p>
          </div>
          <button class="btn-primary" onclick="openAddGuestModal()"
            >+ Adicionar Convidado</button
          >
        </div>

        <!-- Busca -->
        <div
          style="display:flex; gap:0.75rem; margin-bottom:1.5rem; flex-wrap:wrap;"
        >
          <input
            type="text"
            id="guest-search"
            placeholder="Buscar por nome..."
            class="form-input"
            style="flex:1; min-width:200px;"
            oninput="filterGuests()"
          />
          <select
            id="filter-status"
            class="form-input"
            style="width:auto; min-width:160px;"
            onchange="filterGuests()"
          >
            <option value="">Todos os status</option>
            <option value="true">Confirmados</option>
            <option value="false">Recusados</option>
            <option value="null">Pendentes</option>
          </select>
        </div>

        <!-- Tabela -->
        <div class="glass-card" style="overflow:hidden;">
          <div style="overflow-x:auto;">
            <table
              style="width:100%; border-collapse:collapse;"
              id="guests-table"
            >
              <thead>
                <tr
                  style="background:rgba(171,147,224,0.1); border-bottom:2px solid rgba(171,147,224,0.2);"
                >
                  <th class="th">Nome</th>
                  <th class="th">Grupo</th>
                  <th class="th">Status</th>
                  <th class="th">Restrição</th>
                  <th class="th" style="text-align:center;">Ações</th>
                </tr>
              </thead>
              <tbody id="guests-tbody">
                <tr
                  ><td
                    colspan="5"
                    style="text-align:center; padding:2rem; color:var(--texto-suave);"
                    >Carregando... 💜</td
                  ></tr
                >
              </tbody>
            </table>
          </div>
          <!-- Paginação -->
          <div
            style="display:flex; justify-content:space-between; align-items:center; padding:1rem 1.5rem; border-top:1px solid rgba(171,147,224,0.15);"
          >
            <span
              id="guests-count"
              style="font-size:0.85rem; color:var(--texto-suave);"></span>
            <div style="display:flex; gap:0.5rem;" id="pagination"></div>
          </div>
        </div>
      </div>

      <!-- TAB: Mensagens -->
      <div id="tab-messages" class="tab-content" style="display:none;">
        <h1
          style=" font-size:2.5rem; color:var(--lavanda-dark); margin-bottom:0.25rem;"
        >
          Mensagens
        </h1>
        <p style="color:var(--texto-suave); margin-bottom:2rem;">
          Mensagens carinhosas dos seus convidados
        </p>
        <div id="messages-list" style="display:grid; gap:1rem;">
          <p style="color:var(--texto-suave); text-align:center; padding:2rem;">
            Carregando mensagens... 💜
          </p>
        </div>
      </div>

      <!-- TAB: Exportar -->
      <div id="tab-export" class="tab-content" style="display:none;">
        <h1
          style=" font-size:2.5rem; color:var(--lavanda-dark); margin-bottom:0.25rem;"
        >
          Exportar Lista
        </h1>
        <p style="color:var(--texto-suave); margin-bottom:2rem;">
          Baixe a lista de convidados para compartilhar com o cerimonial
        </p>

        <div style="display:grid; gap:1.25rem; max-width:480px;">
          <div class="glass-card" style="padding:1.75rem;">
            <h3
              style=" font-size:1.5rem; color:var(--lavanda-dark); margin-bottom:0.5rem;"
            >
              📊 Lista Completa (CSV)
            </h3>
            <p
              style="color:var(--texto-suave); font-size:0.9rem; margin-bottom:1.25rem;"
            >
              Todos os convidados com nome, grupo, status e restrições
              alimentares.
            </p>
            <button
              class="btn-primary"
              onclick="exportCSV('all')"
              style="width:100%; justify-content:center;"
            >
              ⬇️ Baixar CSV Completo
            </button>
          </div>

          <div class="glass-card" style="padding:1.75rem;">
            <h3
              style=" font-size:1.5rem; color:var(--menta-dark); margin-bottom:0.5rem;"
            >
              ✅ Apenas Confirmados (CSV)
            </h3>
            <p
              style="color:var(--texto-suave); font-size:0.9rem; margin-bottom:1.25rem;"
            >
              Somente os convidados que confirmaram presença.
            </p>
            <button
              class="btn-outline"
              onclick="exportCSV('confirmed')"
              style="width:100%; justify-content:center; border-color:var(--menta); color:var(--menta-dark);"
            >
              ⬇️ Baixar Confirmados
            </button>
          </div>
        </div>
      </div>

      <!-- TAB: Presentes -->
      <div id="tab-presentes" class="tab-content" style="display:none;">
        <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:1rem; margin-bottom:2rem;">
          <div>
            <h1 style="font-size:2.5rem; color:var(--lavanda-dark); margin-bottom:0.25rem;">Presentes</h1>
            <p style="color:var(--texto-suave);">Gerencie a lista de casamento</p>
          </div>
          <button class="btn-primary" onclick="openAddPresenteModal()">+ Adicionar Presente</button>
        </div>

        <!-- Métricas rápidas -->
        <div style="display:flex; gap:1rem; flex-wrap:wrap; margin-bottom:1.5rem;">
          <div style="background:linear-gradient(135deg,var(--lavanda),var(--azul)); color:white; border-radius:14px; padding:1rem 1.5rem; flex:1; min-width:120px;">
            <div style="font-size:1.8rem; font-weight:700;" id="p-total">—</div>
            <div style="font-size:0.8rem; opacity:0.9;">Total</div>
          </div>
          <div style="background:linear-gradient(135deg,var(--menta-dark),#52c77a); color:white; border-radius:14px; padding:1rem 1.5rem; flex:1; min-width:120px;">
            <div style="font-size:1.8rem; font-weight:700;" id="p-reservados">—</div>
            <div style="font-size:0.8rem; opacity:0.9;">Reservados ✅</div>
          </div>
          <div style="background:linear-gradient(135deg,#e0c07b,#c9a840); color:white; border-radius:14px; padding:1rem 1.5rem; flex:1; min-width:120px;">
            <div style="font-size:1.8rem; font-weight:700;" id="p-disponiveis">—</div>
            <div style="font-size:0.8rem; opacity:0.9;">Disponíveis</div>
          </div>
        </div>

        <!-- Tabela -->
        <div class="glass-card" style="overflow:hidden;">
          <div style="overflow-x:auto;">
            <table style="width:100%; border-collapse:collapse;" id="presentes-table">
              <thead>
                <tr style="background:rgba(171,147,224,0.1); border-bottom:2px solid rgba(171,147,224,0.2);">
                  <th class="th">Presente</th>
                  <th class="th">Categoria</th>
                  <th class="th">Preço</th>
                  <th class="th">Status</th>
                  <th class="th">Quem Reservou</th>
                  <th class="th" style="text-align:center;">Ações</th>
                </tr>
              </thead>
              <tbody id="presentes-tbody">
                <tr><td colspan="6" style="text-align:center; padding:2rem; color:var(--texto-suave);">Carregando... 💜</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </main>
  </div>

  <!-- ── Modal: Adicionar/Editar Convidado ──────────────── -->
  <div
    id="guest-modal"
    style="display:none; position:fixed; inset:0; z-index:1000; background:rgba(0,0,0,0.4); backdrop-filter:blur(4px); align-items:center; justify-content:center;"
  >
    <div
      class="glass-card"
      style="width:100%; max-width:480px; padding:2rem; margin:1rem; animation:fadeInUp 0.3s ease;"
    >
      <h2
        id="modal-title"
        style=" font-size:2rem; color:var(--lavanda-dark); margin-bottom:1.5rem;"
      >
        Adicionar Convidado
      </h2>

      <form id="guest-form" onsubmit="saveGuest(event)">
        <input type="hidden" id="guest-id" value="" />

        <div style="margin-bottom:1.1rem;">
          <label
            style="display:block; font-size:0.85rem; font-weight:600; color:var(--texto-suave); margin-bottom:0.35rem;"
            >Nome Completo *</label
          >
          <input
            type="text"
            id="g-nome"
            class="form-input"
            placeholder="Nome do convidado"
            required
          />
        </div>

        <div style="margin-bottom:1.1rem;">
          <label
            style="display:block; font-size:0.85rem; font-weight:600; color:var(--texto-suave); margin-bottom:0.35rem;"
            >Grupo Familiar</label
          >
          <select id="g-grupo" class="form-input">
            <option value="">— Sem grupo / criar novo —</option>
          </select>
        </div>

        <div style="margin-bottom:1.1rem;">
          <label
            style="display:block; font-size:0.85rem; font-weight:600; color:var(--texto-suave); margin-bottom:0.35rem;"
            >Nome do Novo Grupo (se criar)</label
          >
          <input
            type="text"
            id="g-novo-grupo"
            class="form-input"
            placeholder="Ex: Família Silva, João & Maria"
          />
        </div>

        <div style="margin-bottom:1.1rem;">
          <label
            style="display:block; font-size:0.85rem; font-weight:600; color:var(--texto-suave); margin-bottom:0.35rem;"
            >Restrição Alimentar</label
          >
          <input
            type="text"
            id="g-restricao"
            class="form-input"
            placeholder="Ex: vegano, sem glúten..."
          />
        </div>

        <div
          style="margin-bottom:1.5rem; display:flex; align-items:center; gap:0.75rem;"
        >
          <input
            type="checkbox"
            id="g-crianca"
            style="width:18px;height:18px;accent-color:var(--lavanda-dark);"
          />
          <label
            for="g-crianca"
            style="font-size:0.9rem; color:var(--texto); cursor:pointer;"
            >É criança?</label
          >
        </div>

        <div style="display:flex; gap:0.75rem;">
          <button
            type="submit"
            class="btn-primary"
            style="flex:1; justify-content:center;">💾 Salvar</button
          >
          <button
            type="button"
            class="btn-outline"
            onclick="closeModal()"
            style="flex:1; justify-content:center;">Cancelar</button
          >
        </div>
      </form>
    </div>
  </div>

  <!-- ── Modal: Adicionar/Editar Presente ──────────────── -->
  <div
    id="presente-modal"
    style="display:none; position:fixed; inset:0; z-index:1001; background:rgba(0,0,0,0.4); backdrop-filter:blur(4px); align-items:center; justify-content:center;"
  >
    <div class="glass-card" style="width:100%; max-width:480px; padding:2rem; margin:1rem; animation:fadeInUp 0.3s ease; max-height:90vh; overflow-y:auto;">
      <h2 id="presente-modal-title" style="font-size:1.8rem; color:var(--lavanda-dark); margin-bottom:1.5rem;">Adicionar Presente</h2>

      <form id="presente-form" onsubmit="savePresente(event)">
        <input type="hidden" id="p-id" value="" />

        <div style="margin-bottom:1rem;">
          <label style="display:block; font-size:0.85rem; font-weight:600; color:var(--texto-suave); margin-bottom:0.35rem;">Nome *</label>
          <input type="text" id="p-nome" class="form-input" placeholder="Ex: Jogo de Panelas Tramontina" required />
        </div>

        <div style="margin-bottom:1rem;">
          <label style="display:block; font-size:0.85rem; font-weight:600; color:var(--texto-suave); margin-bottom:0.35rem;">Descrição</label>
          <input type="text" id="p-descricao" class="form-input" placeholder="Breve descrição do produto" />
        </div>

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem; margin-bottom:1rem;">
          <div>
            <label style="display:block; font-size:0.85rem; font-weight:600; color:var(--texto-suave); margin-bottom:0.35rem;">Preço (R$) *</label>
            <input type="number" id="p-preco" class="form-input" placeholder="0,00" step="0.01" min="0" required />
          </div>
          <div>
            <label style="display:block; font-size:0.85rem; font-weight:600; color:var(--texto-suave); margin-bottom:0.35rem;">Categoria</label>
            <select id="p-categoria" class="form-input">
              <option value="Cozinha">🍳 Cozinha</option>
              <option value="Quarto">🛏️ Quarto</option>
              <option value="Banheiro">🛁 Banheiro</option>
              <option value="Casa">🏡 Casa</option>
              <option value="Eletrodomésticos">⚡ Eletrodomésticos</option>
              <option value="Decoração">🌸 Decoração</option>
              <option value="Outros" selected>🎁 Outros</option>
            </select>
          </div>
        </div>

        <div style="margin-bottom:1.5rem;">
          <label style="display:block; font-size:0.85rem; font-weight:600; color:var(--texto-suave); margin-bottom:0.35rem;">URL da Imagem (opcional)</label>
          <input type="url" id="p-imagem" class="form-input" placeholder="https://..." />
        </div>

        <div style="display:flex; gap:0.75rem;">
          <button type="submit" class="btn-primary" style="flex:1; justify-content:center;">💾 Salvar</button>
          <button type="button" class="btn-outline" onclick="closePresenteModal()" style="flex:1; justify-content:center;">Cancelar</button>
        </div>
      </form>
    </div>
  </div>
</Layout>

<style>
  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-radius: 10px;
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.25rem;
    transition: all 0.2s ease;
    cursor: pointer;
    border: none;
    background: none;
    width: 100%;
    text-align: left;
  }
  .sidebar-link:hover,
  .active-link {
    background: rgba(255, 255, 255, 0.15);
    color: white;
  }

  .metric-card {
    padding: 1.5rem;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }
  .metric-number {
    font-family: "Rochester", cursive;
    font-size: 3rem;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 0.25rem;
  }
  .metric-label {
    font-size: 0.85rem;
    opacity: 0.9;
    font-weight: 600;
  }

  .th {
    padding: 1rem 1.25rem;
    text-align: left;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--lavanda-dark);
  }

  .td {
    padding: 0.875rem 1.25rem;
    font-size: 0.9rem;
    color: var(--texto);
    border-bottom: 1px solid rgba(171, 147, 224, 0.1);
    vertical-align: middle;
  }

  .badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 700;
  }
  .badge-ok {
    background: rgba(173, 235, 179, 0.35);
    color: var(--menta-dark);
  }
  .badge-no {
    background: rgba(224, 147, 147, 0.25);
    color: #c0504d;
  }
  .badge-wait {
    background: rgba(224, 192, 123, 0.3);
    color: #9a7820;
  }
</style>

<script>
  // BASE: vazio em dev (proxy Vite /api/* → localhost:8080) | URL completa em prod
  const API_BASE = import.meta.env.PUBLIC_API_URL ?? "";

  // ── Estado global ──────────────────────────────────── //
  let allGuests = [];
  let filteredGuests = [];
  let currentPage = 1;
  const PER_PAGE = 15;

  // ── Tabs ──────────────────────────────────────────── //
  function showTab(tab, el) {
    document
      .querySelectorAll(".tab-content")
      .forEach((t) => (t.style.display = "none"));
    document
      .querySelectorAll(".sidebar-link")
      .forEach((l) => l.classList.remove("active-link"));
    document.getElementById(`tab-${tab}`).style.display = "block";
    el?.classList.add("active-link");

    if (tab === "guests") loadGuests();
    if (tab === "overview") loadOverview();
    if (tab === "messages") loadMessages();
  }

  // ── Carregar Visão Geral ───────────────────────────── //
  async function loadOverview() {
    try {
      const res = await authFetch("/api/admin/guests?per_page=1000&page=1");
      if (!res.ok) {
        redirectToLogin();
        return;
      }
      const data = await res.json();

      const guests = data.guests || [];
      const total = guests.length;
      const confirmed = guests.filter((g) => g.confirmado === true).length;
      const declined = guests.filter((g) => g.confirmado === false).length;
      const pending = guests.filter((g) => g.confirmado === null).length;
      const pct = total > 0 ? Math.round((confirmed / total) * 100) : 0;

      document.getElementById("m-total").textContent = total;
      document.getElementById("m-confirmados").textContent = confirmed;
      document.getElementById("m-recusados").textContent = declined;
      document.getElementById("m-pendentes").textContent = pending;
      document.getElementById("progress-pct").textContent = pct + "%";
      document.getElementById("prog-confirmed").textContent =
        `${confirmed} confirmados`;
      document.getElementById("prog-total").textContent =
        `de ${total} convidados`;

      setTimeout(() => {
        document.getElementById("progress-bar").style.width = pct + "%";
      }, 100);

      document.getElementById("overview-loading").style.display = "none";
    } catch {
      document.getElementById("overview-loading").innerHTML =
        "⚠️ Não foi possível carregar os dados. Verifique se o backend está rodando.";
    }
  }

  // ── Carregar Convidados ────────────────────────────── //
  async function loadGuests() {
    try {
      const res = await authFetch("/api/admin/guests?per_page=1000&page=1");
      if (!res.ok) {
        redirectToLogin();
        return;
      }
      const data = await res.json();
      allGuests = data.guests || [];
      filteredGuests = [...allGuests];
      currentPage = 1;
      renderGuestsTable();
      loadGroupsForSelect();
    } catch {
      document.getElementById("guests-tbody").innerHTML =
        '<tr><td colspan="5" style="text-align:center;padding:2rem;color:#c0504d;">⚠️ Erro ao carregar convidados.</td></tr>';
    }
  }

  function filterGuests() {
    const search = document.getElementById("guest-search").value.toLowerCase();
    const status = document.getElementById("filter-status").value;

    filteredGuests = allGuests.filter((g) => {
      const matchName = g.nome_completo.toLowerCase().includes(search);
      const matchStatus =
        status === ""
          ? true
          : status === "null"
            ? g.confirmado === null
            : g.confirmado === (status === "true");
      return matchName && matchStatus;
    });

    currentPage = 1;
    renderGuestsTable();
  }

  function renderGuestsTable() {
    const tbody = document.getElementById("guests-tbody");
    const start = (currentPage - 1) * PER_PAGE;
    const pageGuests = filteredGuests.slice(start, start + PER_PAGE);

    document.getElementById("guests-count").textContent =
      `Exibindo ${Math.min(start + 1, filteredGuests.length)}–${Math.min(start + PER_PAGE, filteredGuests.length)} de ${filteredGuests.length} convidados`;

    if (pageGuests.length === 0) {
      tbody.innerHTML =
        '<tr><td colspan="5" style="text-align:center;padding:2rem;color:var(--texto-suave);">Nenhum convidado encontrado.</td></tr>';
      renderPagination();
      return;
    }

    tbody.innerHTML = pageGuests
      .map((g) => {
        const badge =
          g.confirmado === true
            ? '<span class="badge badge-ok">✅ Confirmado</span>'
            : g.confirmado === false
              ? '<span class="badge badge-no">❌ Não vai</span>'
              : '<span class="badge badge-wait">⏳ Pendente</span>';

        return `<tr style="transition:background 0.15s;" onmouseenter="this.style.background='rgba(171,147,224,0.05)'" onmouseleave="this.style.background='transparent'">
        <td class="td"><strong>${g.nome_completo}</strong>${g.eh_crianca ? ' <span style="font-size:0.7rem;background:var(--lavanda-light);color:var(--lavanda-dark);padding:2px 7px;border-radius:20px;margin-left:4px;">criança</span>' : ""}</td>
        <td class="td" style="color:var(--texto-suave);">${g.nome_grupo || "—"}</td>
        <td class="td">${badge}</td>
        <td class="td" style="color:var(--texto-suave); font-size:0.85rem;">${g.restricao_alimentar || "—"}</td>
        <td class="td" style="text-align:center;">
          <button onclick="editGuest(${g.id})" style="background:none;border:none;cursor:pointer;font-size:1rem;padding:4px 8px;" title="Editar">✏️</button>
          <button onclick="deleteGuest(${g.id}, '${g.nome_completo.replace(/'/g, "\\'")}')" style="background:none;border:none;cursor:pointer;font-size:1rem;padding:4px 8px;" title="Remover">🗑️</button>
        </td>
      </tr>`;
      })
      .join("");

    renderPagination();
  }

  function renderPagination() {
    const totalPages = Math.ceil(filteredGuests.length / PER_PAGE);
    const container = document.getElementById("pagination");
    if (totalPages <= 1) {
      container.innerHTML = "";
      return;
    }

    let html = "";
    for (let i = 1; i <= totalPages; i++) {
      html += `<button onclick="goPage(${i})" style="
        width:32px; height:32px; border-radius:8px; border:1px solid var(--lavanda-light);
        background:${i === currentPage ? "var(--lavanda)" : "white"};
        color:${i === currentPage ? "white" : "var(--lavanda-dark)"};
        cursor:pointer; font-size:0.85rem; font-family:'Quicksand'; font-weight:600;
      ">${i}</button>`;
    }
    container.innerHTML = html;
  }

  function goPage(p) {
    currentPage = p;
    renderGuestsTable();
  }

  // ── Modal de Convidado ─────────────────────────────── //
  function openAddGuestModal() {
    document.getElementById("modal-title").textContent = "Adicionar Convidado";
    document.getElementById("guest-id").value = "";
    document.getElementById("g-nome").value = "";
    document.getElementById("g-restricao").value = "";
    document.getElementById("g-crianca").checked = false;
    document.getElementById("g-novo-grupo").value = "";
    document.getElementById("guest-modal").style.display = "flex";
  }

  function editGuest(id) {
    const g = allGuests.find((x) => x.id === id);
    if (!g) return;
    document.getElementById("modal-title").textContent = "Editar Convidado";
    document.getElementById("guest-id").value = id;
    document.getElementById("g-nome").value = g.nome_completo;
    document.getElementById("g-restricao").value = g.restricao_alimentar || "";
    document.getElementById("g-crianca").checked = g.eh_crianca;
    const sel = document.getElementById("g-grupo");
    sel.value = g.grupo_id || "";
    document.getElementById("guest-modal").style.display = "flex";
  }

  function closeModal() {
    document.getElementById("guest-modal").style.display = "none";
  }

  async function saveGuest(e) {
    e.preventDefault();
    const id = document.getElementById("guest-id").value;
    const body = {
      nome_completo: document.getElementById("g-nome").value,
      grupo_id: document.getElementById("g-grupo").value
        ? Number(document.getElementById("g-grupo").value)
        : null,
      nome_grupo_novo: document.getElementById("g-novo-grupo").value || null,
      restricao_alimentar: document.getElementById("g-restricao").value || null,
      eh_crianca: document.getElementById("g-crianca").checked,
    };

    const url = id ? `/api/admin/guests/${id}` : "/api/admin/guests";
    const method = id ? "PUT" : "POST";

    const res = await authFetch(url, { method, body: JSON.stringify(body) });
    if (res.ok) {
      closeModal();
      loadGuests();
      loadOverview();
    } else {
      alert("Erro ao salvar convidado.");
    }
  }

  async function deleteGuest(id, nome) {
    if (!confirm(`Remover "${nome}" da lista?`)) return;
    const res = await authFetch(`/api/admin/guests/${id}`, {
      method: "DELETE",
    });
    if (res.ok) {
      loadGuests();
      loadOverview();
    } else {
      alert("Erro ao remover convidado.");
    }
  }

  // ── Grupos no select do modal ──────────────────────── //
  async function loadGroupsForSelect() {
    try {
      const res = await authFetch("/api/admin/groups");
      if (!res.ok) return;
      const data = await res.json();
      const sel = document.getElementById("g-grupo");
      const groups = data.groups || [];
      sel.innerHTML =
        '<option value="">— Sem grupo / criar novo —</option>' +
        groups
          .map((g) => `<option value="${g.id}">${g.nome_grupo}</option>`)
          .join("");
    } catch {}
  }

  // ── Mensagens ──────────────────────────────────────── //
  async function loadMessages() {
    try {
      const res = await authFetch("/api/admin/messages");
      if (!res.ok) {
        redirectToLogin();
        return;
      }
      const data = await res.json();
      const msgs = data.messages || [];
      const container = document.getElementById("messages-list");
      if (!msgs.length) {
        container.innerHTML =
          '<p style="color:var(--texto-suave);text-align:center;padding:2rem;">Nenhuma mensagem ainda. 💜</p>';
        return;
      }
      container.innerHTML = msgs
        .map(
          (m) => `
        <div class="glass-card" style="padding:1.5rem;">
          <p style="font-weight:700; color:var(--lavanda-dark); margin-bottom:0.25rem;">${m.nome}</p>
          <p style="color:var(--texto-suave); font-style:italic; font-size:0.9rem; margin-bottom:0.75rem;">"${m.mensagem}"</p>
          <p style="font-size:0.75rem; color:#b0a8c8;">${new Date(m.data).toLocaleDateString("pt-BR")}</p>
        </div>`,
        )
        .join("");
    } catch {
      document.getElementById("messages-list").innerHTML =
        '<p style="color:#c0504d;text-align:center;padding:2rem;">⚠️ Erro ao carregar mensagens.</p>';
    }
  }

  // ── Exportar CSV ───────────────────────────────────── //
  async function exportCSV(type) {
    const url =
      type === "confirmed"
        ? "/api/admin/export/csv?status=confirmed"
        : "/api/admin/export/csv";
    try {
      const res = await authFetch(url);
      if (!res.ok) throw new Error();
      const blob = await res.blob();
      const a = document.createElement("a");
      a.href = URL.createObjectURL(blob);
      a.download = `convidados_${type}_${new Date().toISOString().slice(0, 10)}.csv`;
      a.click();
    } catch {
      alert("Erro ao exportar. Verifique se o backend está rodando.");
    }
  }

  // ── Auth helpers ──────────────────────────────────── //
  function authFetch(path, opts = {}) {
    // path já inclui /api/... (ex: '/api/admin/guests')
    return fetch(`${API_BASE}${path}`, {
      ...opts,
      credentials: "include",
      headers: { "Content-Type": "application/json", ...(opts.headers || {}) },
    });
  }

  function redirectToLogin() {
    window.location.href = "/admin/login";
  }

  function handleLogout() {
    authFetch("/api/admin/logout", { method: "POST" }).finally(() => {
      window.location.href = "/admin/login";
    });
  }

  // ── Fechar modal clicando fora ─────────────────────── //
  document
    .getElementById("guest-modal")
    .addEventListener("click", function (e) {
      if (e.target === this) closeModal();
    });

  document
    .getElementById("presente-modal")
    .addEventListener("click", function (e) {
      if (e.target === this) closePresenteModal();
    });

  // ── Presentes ──────────────────────────────────────── //
  let allPresentes = [];

  async function loadPresentes() {
    try {
      const res = await authFetch("/api/admin/presentes");
      if (res.status === 401) { redirectToLogin(); return; }
      if (!res.ok) {
        document.getElementById("presentes-tbody").innerHTML =
          '<tr><td colspan="6" style="text-align:center;padding:2rem;color:#c0504d;">⚠️ Tabela de presentes não encontrada. Execute a migração no banco de dados.</td></tr>';
        return;
      }
      const data = await res.json();
      allPresentes = data.presentes || [];
      renderPresentesTable();

      const reservados   = allPresentes.filter(p => p.reservado).length;
      const disponiveis  = allPresentes.length - reservados;
      document.getElementById("p-total").textContent       = allPresentes.length;
      document.getElementById("p-reservados").textContent  = reservados;
      document.getElementById("p-disponiveis").textContent = disponiveis;
    } catch {
      document.getElementById("presentes-tbody").innerHTML =
        '<tr><td colspan="6" style="text-align:center;padding:2rem;color:#c0504d;">⚠️ Erro ao carregar presentes.</td></tr>';
    }
  }

  function renderPresentesTable() {
    const tbody = document.getElementById("presentes-tbody");
    if (!allPresentes.length) {
      tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:2rem;color:var(--texto-suave);">Nenhum presente cadastrado ainda.</td></tr>';
      return;
    }

    const fmt = v => Number(v).toLocaleString("pt-BR", { style: "currency", currency: "BRL" });

    tbody.innerHTML = allPresentes.map(p => {
      const badge = p.reservado
        ? '<span class="badge badge-ok">✅ Reservado</span>'
        : '<span class="badge badge-wait">⬜ Disponível</span>';
      return `<tr style="transition:background 0.15s;" onmouseenter="this.style.background='rgba(171,147,224,0.05)'" onmouseleave="this.style.background='transparent'">
        <td class="td"><strong>${p.nome}</strong><br/><span style="font-size:0.8rem;color:var(--texto-suave);">${p.descricao || ""}</span></td>
        <td class="td" style="color:var(--texto-suave);">${p.categoria}</td>
        <td class="td" style="font-weight:700;color:var(--lavanda-dark);">${fmt(p.preco)}</td>
        <td class="td">${badge}</td>
        <td class="td" style="color:var(--texto-suave);font-size:0.85rem;">${p.reservado_por || "—"}</td>
        <td class="td" style="text-align:center;white-space:nowrap;">
          <button onclick="editPresente(${p.id})" style="background:none;border:none;cursor:pointer;font-size:1rem;padding:4px 6px;" title="Editar">✏️</button>
          ${p.reservado
            ? `<button onclick="liberarReserva(${p.id})" style="background:none;border:none;cursor:pointer;font-size:1rem;padding:4px 6px;" title="Liberar reserva">🔓</button>`
            : ""}
          <button onclick="deletePresente(${p.id}, '${p.nome.replace(/'/g, "\\'")}')" style="background:none;border:none;cursor:pointer;font-size:1rem;padding:4px 6px;" title="Remover">🗑️</button>
        </td>
      </tr>`;
    }).join("");
  }

  function openAddPresenteModal() {
    document.getElementById("presente-modal-title").textContent = "Adicionar Presente";
    document.getElementById("p-id").value = "";
    document.getElementById("p-nome").value = "";
    document.getElementById("p-descricao").value = "";
    document.getElementById("p-preco").value = "";
    document.getElementById("p-categoria").value = "Outros";
    document.getElementById("p-imagem").value = "";
    document.getElementById("presente-modal").style.display = "flex";
  }

  function editPresente(id) {
    const p = allPresentes.find(x => x.id === id);
    if (!p) return;
    document.getElementById("presente-modal-title").textContent = "Editar Presente";
    document.getElementById("p-id").value = id;
    document.getElementById("p-nome").value = p.nome;
    document.getElementById("p-descricao").value = p.descricao || "";
    document.getElementById("p-preco").value = p.preco;
    document.getElementById("p-categoria").value = p.categoria || "Outros";
    document.getElementById("p-imagem").value = p.imagem_url || "";
    document.getElementById("presente-modal").style.display = "flex";
  }

  function closePresenteModal() {
    document.getElementById("presente-modal").style.display = "none";
  }

  async function savePresente(e) {
    e.preventDefault();
    const id   = document.getElementById("p-id").value;
    const body = {
      nome:      document.getElementById("p-nome").value,
      descricao: document.getElementById("p-descricao").value || "",
      preco:     Number(document.getElementById("p-preco").value),
      categoria: document.getElementById("p-categoria").value,
      imagem_url: document.getElementById("p-imagem").value || "",
    };
    const url    = id ? `/api/admin/presentes/${id}` : "/api/admin/presentes";
    const method = id ? "PUT" : "POST";
    const res    = await authFetch(url, { method, body: JSON.stringify(body) });
    if (res.ok || res.status === 204) { closePresenteModal(); loadPresentes(); }
    else { alert("Erro ao salvar presente."); }
  }

  async function deletePresente(id, nome) {
    if (!confirm(`Remover "${nome}" da lista?`)) return;
    const res = await authFetch(`/api/admin/presentes/${id}`, { method: "DELETE" });
    if (res.ok || res.status === 204) loadPresentes();
    else alert("Erro ao remover presente.");
  }

  async function liberarReserva(id) {
    if (!confirm("Liberar a reserva desse presente? Ele voltará a ficar disponível.")) return;
    const res = await authFetch(`/api/admin/presentes/${id}/liberar`, { method: "POST" });
    if (res.ok) loadPresentes();
    else alert("Erro ao liberar reserva.");
  }

  // ── Expor funções globais ──────────────────────────── //
  window.showTab = showTab;
  window.filterGuests = filterGuests;
  window.goPage = goPage;
  window.openAddGuestModal = openAddGuestModal;
  window.editGuest = editGuest;
  window.closeModal = closeModal;
  window.saveGuest = saveGuest;
  window.deleteGuest = deleteGuest;
  window.exportCSV = exportCSV;
  window.handleLogout = handleLogout;
  // Presentes
  window.openAddPresenteModal = openAddPresenteModal;
  window.editPresente = editPresente;
  window.closePresenteModal = closePresenteModal;
  window.savePresente = savePresente;
  window.deletePresente = deletePresente;
  window.liberarReserva = liberarReserva;

  // ── showTab atualizado para carregar presentes ──────── //
  // (o showTab original está definido acima — sobrescrevemos aqui)
  const _showTabOrig = window.showTab;
  window.showTab = function(tab, el) {
    _showTabOrig(tab, el);
    if (tab === "presentes") loadPresentes();
  };

  // ── Init ───────────────────────────────────────────── //
  loadOverview();
</script>
